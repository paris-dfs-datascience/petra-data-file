# Runtime mode
# ENABLE_UI=true
# LOCAL_WORKDIR=data/tmp

# OpenAI
# OPENAI_API_KEY=
# OPEN_AI_API_KEY=
# TEXT_PROVIDER=openai
# VISION_PROVIDER=openai
# OPENAI_TEXT_MODEL=gpt-5.4-mini
# OPENAI_VISION_MODEL=gpt-5.4
# OPENAI_TEXT_TEMPERATURE=

# Claude / Anthropic
# ANTHROPIC_API_KEY=  # also accepts ANTHROPIC_AI_API_KEY or ANTROPIC_AI_API_KEY
# CLAUDE_TEXT_MODEL=claude-sonnet-4-6
# CLAUDE_VISION_MODEL=claude-sonnet-4-6
# CLAUDE_TEXT_TEMPERATURE=
# CLAUDE_VISION_TEMPERATURE=
# CLAUDE_TEXT_MAX_TOKENS=1600
# CLAUDE_VISION_MAX_TOKENS=1600

# Persistence is disabled by design. Uploaded PDFs are processed from temporary files and removed after analysis.

# Auth bootstrap user
# APP_ADMIN_EMAIL=admin@example.com
# APP_ADMIN_PASSWORD=admin
